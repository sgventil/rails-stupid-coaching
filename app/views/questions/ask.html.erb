<div class="container mt-5">
  <h1>Stupid Coaching</h1>
  <form action="/answer" data-turbo="false">
    <div class="form-group">
      <label for="question">Ask your coach anything:</label>
      <div class="input-group">
        <input class="form-control form-control" type="text" name="question">
          <div class="input-group-append">
            <button type="submit" class="btn btn-primary"><strong>Ask</strong></button>
          </div>
      </div>
    </div>
  </form>
</div>
